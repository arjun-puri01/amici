EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — never prefix with EXPO_PUBLIC, never commit the real value
# Find it in: Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Your actual app account email — used by create-dev-match.mjs only
REAL_USER_EMAIL=you@brown.edu
